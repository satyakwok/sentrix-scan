# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore ALL by default, only the checked-in template is allowed
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev artifacts (playwright MCP / research notes / screenshots at repo root)
.playwright-mcp/
# audit screenshots dumped at repo root (any image format)
/*.png
/*.jpg
/*.jpeg
/*.webp
/*.gif

# Claude Code / Cursor / AI-assistant workspace files — never push these.
# User-level skills live at ~/.claude/skills; this catches any project-scoped
# equivalents + local settings + scratch research.
.claude/
.cursor/
.aider*
.continue/
# (if you ever want to commit a specific file under .claude/, negate it
#  explicitly like: !.claude/commands/public-command.md)

# local-only planning + scratch notes (session-off convention, never push)
/TODO.md
/NOTES.md
/ROADMAP.local.md
/local-*.md
/CLAUDE.md
# session handoff / working notes between Claude Code sessions
/SESSION.md
/HANDOFF.md
/SESSION_*.md
/HANDOFF_*.md
/*.handoff.md
/*.session.md
/.session/
/.handoff/

# ── Public-repo safety net (extra patterns in case secrets slip through) ────
# Private keys / certs in any form
*.key
*.pfx
*.p12
*.crt
*.cer
*.keystore
id_rsa
id_ed25519
*.asc
*.gpg

# Wallets / mnemonics / chain operator secrets
wallet.json
mnemonic*
*.mnemonic
seed.txt
secrets.json
credentials.json
service-account*.json
gcloud-key*.json
aws-credentials*

# Local DBs / dumps that could leak user data
*.sqlite
*.sqlite3
*.db
dump*.sql

# Backups / archives named loosely
backup*
*.bak
*.backup

# IDE / editor local state
.idea/
.vscode/
*.swp
*.swo

# macOS junk (already partial above)
Thumbs.db
desktop.ini
